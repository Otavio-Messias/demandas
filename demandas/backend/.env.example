# Copie este arquivo para .env e preencha os valores

# String de conexão com o banco PostgreSQL
# Exemplo local: postgresql://postgres:senha@localhost:5432/demandas
# O Render fornece essa URL automaticamente
DATABASE_URL=postgresql://usuario:senha@localhost:5432/demandas

# Chave secreta para os tokens de login (coloque qualquer texto longo)
JWT_SECRET=troque_por_uma_chave_secreta_bem_longa_aqui

# URL do frontend (necessário no Render)
# FRONTEND_URL=https://seu-frontend.onrender.com
